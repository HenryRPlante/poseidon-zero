{
  "name": "Poseidon Zero",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:18",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "forwardPorts": [4200, 5000, 8080, 8888],
  "portsAttributes": {
    "4200": {
      "label": "Angular Dev Server",
      "onAutoForward": "notify"
    },
    "5000": {
      "label": "Flask Receiver",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Arduino HTTP",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "node",
  "postCreateCommand": "npm install && python3 -m pip install -r scripts/requirements.txt -r server/requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "Angular.ng-template",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "runArgs": [
    "--device=/dev/ttyACM0:/dev/ttyACM0",
    "--device=/dev/ttyUSB0:/dev/ttyUSB0",
    "--privileged"
  ]
}
